# ---------------------------------------------------------------------------
# Client Issue Tracker — Environment Variables (example)
# Copy to .env and fill in. Missing optional keys degrade gracefully (the
# related feature disables itself) instead of crashing the app (.clauderules §3).
# ---------------------------------------------------------------------------

# ---- Database (Supabase Postgres) — REQUIRED ----
# Pooled (PgBouncer) connection used by the app at runtime:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection used by Prisma Migrate:
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ---- Auth (custom JWT) — REQUIRED ----
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ---- AI providers (OPTIONAL — feature disables if all are absent) ----
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ---- S3 / object storage (OPTIONAL — attachments disable if absent) ----
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ---- SMTP / email (OPTIONAL — email notifications disable if absent) ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ---- Web Push / Vapid (OPTIONAL) ----
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"

# ---- Rate limiting ----
# Always-on, in-memory (no external service / keys required). Limits are
# per-process; see PRODUCTION_READINESS.md for the multi-instance note.

# ---- Google reCAPTCHA (OPTIONAL — captcha check skipped if absent) ----
RECAPTCHA_SECRET_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
