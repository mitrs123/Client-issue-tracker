{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "//regions": "Run functions in Seoul (icn1) — same region as the Supabase DB (ap-northeast-2). Co-locating server and database turns each query round-trip from ~200-400ms (cross-ocean) into single-digit ms.",
  "regions": ["icn1"],
  "crons": [
    { "path": "/api/notifications/dispatch", "schedule": "0 0 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        { "key": "X-DNS-Prefetch-Control", "value": "on" }
      ]
    }
  ]
}
